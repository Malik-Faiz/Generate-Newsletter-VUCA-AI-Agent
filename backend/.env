# Copy this file to .env (or export these as real environment variables).
# Get a free Groq API key (no credit card required) at:
#   https://console.groq.com/keys

GROQ_API_KEY=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

# Optional overrides
GROQ_MODEL=openai/gpt-oss-120b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
PORT=7755

# Prompt-size limits, tuned to fit Groq's free-tier tokens/minute cap
# (openai/gpt-oss-120b is limited to 8,000 TPM on the free tier as of
# mid-2026 — check https://console.groq.com/docs/rate-limits for
# current numbers). These target a ~2,200-2,600 word newsletter (6
# sections) — close to the practical ceiling for one free-tier call;
# pushing further starts eating into the safety margin against Groq's
# json_object mode rejecting responses that get cut off mid-object.
# An automatic retry with a shorter fallback ask kicks in if a
# generation ever does run out of room.
#
# Trade-off made to hit this length: MAX_SKILL_CHARS and
# MAX_REPORT_CHARS are now quite small (the AI sees less of your
# uploaded report/skill instructions verbatim) so there's more budget
# left over for actual newsletter output. If your reports are long and
# detail from them matters more than newsletter length, lower
# MAX_OUTPUT_TOKENS and raise MAX_REPORT_CHARS instead.
#
# Want MORE than ~2,600 words? Your options, in order of effort:
#   1. Nudge MAX_OUTPUT_TOKENS up in small steps (e.g. +300 at a time)
#      and re-test — you're trading away the remaining safety margin.
#   2. Upgrade to Groq's paid Developer tier (~10x the rate limits,
#      25% cheaper per token) — the real unlock for genuinely long
#      output without walking a tightrope on the free tier.
#   3. Switch to a paid provider (Anthropic, OpenAI, etc.) for
#      significantly larger per-call token budgets — requires swapping
#      the API call in newsletter_ai.py, not just changing these numbers.
MAX_SKILL_CHARS=1500
MAX_REPORT_CHARS=1800
MAX_OUTPUT_TOKENS=5500
